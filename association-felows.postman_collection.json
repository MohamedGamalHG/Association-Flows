    {
      "name": "user",
      "item": [
        {
          "name": "create user",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// allowed prefixes\r",
                  "const prefixes = [\"11\", \"12\", \"10\", \"15\"];\r",
                  "\r",
                  "// pick random prefix\r",
                  "const prefix = prefixes[Math.floor(Math.random() * prefixes.length)];\r",
                  "\r",
                  "// generate 8 random digits\r",
                  "let randomPart = \"\";\r",
                  "for (let i = 0; i < 8; i++) {\r",
                  "    randomPart += Math.floor(Math.random() * 10);\r",
                  "}\r",
                  "\r",
                  "// final number\r",
                  "const mobile = \"0\" + prefix + randomPart;\r",
                  "\r",
                  "const randomName = Math.random().toString(36).substring(2, 10);\r",
                  "\r",
                  "console.log(randomName)\r",
                  "\r",
                  "\r",
                  "// save it\r",
                  "pm.environment.set(\"mobile_number\", mobile);\r",
                  "pm.environment.set(\"var_name\",randomName)\r",
                  "console.log(\"Generated Mobile:\", mobile);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();\r",
