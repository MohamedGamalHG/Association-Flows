<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1-create-installments-table" author="mohamed.gamal">

        <createTable tableName="installments">

            <!-- ID -->
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- FK to users -->
            <column name="slot_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <!-- Financial -->
            <column name="amount" type="DECIMAL(12,2)"/>

            <!-- Dates -->
            <column name="due_date" type="DATE"/><!-- map to LocalDate in java -->
            <column name="paid_at" type="TIMESTAMP WITH TIME ZONE"/>

            <!-- Enum -->
            <column name="status" type="VARCHAR(50)"/>

            <!-- Audit -->
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"
                    defaultValueComputed="CURRENT_TIMESTAMP"/>

            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>


        </createTable>

    </changeSet>

</databaseChangeLog>