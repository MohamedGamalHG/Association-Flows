<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1-create-payments-table" author="mohamed.gamal">

        <createTable tableName="payments">

            <!-- ===== AUDIT COLUMNS ===== -->
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>


            <!-- ===== RELATION ===== -->
            <column name="association_slot_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <!-- ===== PAYMENT DATA ===== -->
            <column name="amount" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>

            <column name="target_month" type="INT"/>

            <column name="payment_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="confirmation_date" type="TIMESTAMP WITH TIME ZONE"/>

            <!-- ===== ENUMS ===== -->
            <column name="status" type="VARCHAR(50)"/>
            <column name="payment_method" type="VARCHAR(50)"/>

            <!-- ===== EXTRA ===== -->
            <column name="attachment_url" type="TEXT"/>
            <column name="member_note" type="TEXT"/>
            <column name="manager_note" type="TEXT"/>

            <column name="is_advance" type="BOOLEAN" defaultValueBoolean="false"/>

            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"
                    defaultValueComputed="CURRENT_TIMESTAMP"/>

            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>

        </createTable>

    </changeSet>

</databaseChangeLog>