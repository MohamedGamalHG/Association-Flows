<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="6-alter-is-vacant-columns-to-reserved-association-slot-table" author="mohamed.gamal">
        <dropColumn tableName="association_slot">
            <!-- this column to say (الدور ده مشغول ولا لسا فاضي حد يخده)-->
            <column name="is_vacant" type="BOOLEAN" defaultValue="false"/>
        </dropColumn>


        <addColumn tableName="association_slot">
            <!-- this column to say (الدور ده مشغول ولا لسا فاضي حد يخده)-->
            <column name="is_reserved" type="BOOLEAN" defaultValue="false"/>
        </addColumn>

    </changeSet>
</databaseChangeLog>