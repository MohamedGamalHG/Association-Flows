<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1-create-associations-table" author="mohamed.gamal">

        <createTable tableName="associations">

            <!-- ID -->
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- FK to users -->
            <column name="owner_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <!-- Basic Info -->
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="TEXT"/>

            <!-- Financial -->
            <column name="monthly_amount" type="DECIMAL(12,2)"/>
            <column name="total_shares" type="INT"/> <!-- map to Integer in java -->
            <column name="total_pool_amount" type="DECIMAL(14,2)"/>

            <!-- Dates -->
            <column name="start_date" type="DATE"/><!-- map to LocalDate in java -->
            <column name="end_date" type="DATE"/>

            <!-- Schedule -->
            <column name="collection_day" type="INT"/>
            <column name="payout_day" type="INT"/>

            <!-- Currency -->
            <column name="currency" type="VARCHAR(10)"/>

            <!-- Enum -->
            <column name="status" type="VARCHAR(50)"/>

            <!-- Audit -->
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"
                    defaultValueComputed="CURRENT_TIMESTAMP"/>

            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>


        </createTable>

    </changeSet>

</databaseChangeLog>