<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Use addUniqueConstraint when:
            - Table already exists
            - You follow proper migration rules
            - You want explicit constraint name
            - You want more control (multi-column unique, etc.)
    -->
    <changeSet id="2-add-unique-phone" author="mohamed.gamal">
        <addUniqueConstraint tableName="users"
                             columnNames="phone_number"
                             constraintName="uk_users_phone"/>
    </changeSet>
</databaseChangeLog>